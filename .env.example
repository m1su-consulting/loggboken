# Kopiera till .env: cp .env.example .env
# .env är gitignorad — den här filen är den delade, incheckade referensen.

# Host-orienterad (för `uv run` lokalt). docker-compose skriver över denna
# med den in-nätverks-hostname:en "postgres" åt app-containern.
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/environment_inventory

# X-API-Key -> {client, source_types}. source_types: null = alla källtyper.
APP_API_KEYS={"dev-rpm-key":{"client":"dev-rpm-agent","source_types":["rpm"]},"dev-k8s-key":{"client":"dev-k8s-agent","source_types":["kubernetes"]},"dev-admin-key":{"client":"dev-admin","source_types":null}}

# Origins som frontend-appen tillåts anropa API:et från (CORS).
APP_CORS_ALLOWED_ORIGINS=["http://localhost:5173"]
